{
    "name": "Example Module",
    "description": "This is an example module configuration.",
    "type": "project", // Type of the module (Top level component, namespaced, etc. tbd if this is needed here but might be useful to decide what parameters are needed)
    "metadata": {
        "author": "John Doe",
        "license": "MIT",
        "version": "1.0"
    },
    "parameter_sources": { // If we use the type field stuff like this might be something thats only defined on a project level
        "source1": {
            "type": "file",
            "path": "/data/source1.csv",
            "environment": "env.ENVIRONMENT", // Maybe we can have different parameters for different environments that way we can easily switch between them without having to change the config file
            "version": "1.0" // allow them to pin a version rather than always fetching the latest.
        },
        "source2": {
            "type": "database",
            "connection_string": "Server=myServerAddress;Database=myDataBase;User Id=myUsername;Password=myPassword;"
        },
        "source3": {
            "type": "environment_variable",
            "endpoint": "https://api.example.com/data"
        }
    },
    "module_sources": {
        "source1": {
            "type": "folder", // We could define a folder modules by default 
            "path": "{env.BASE_PATH}/modules/" // Maybe we can use omegaconf to help us with the config construction
        },
        "source2": {
            "type": "folder",
            "path": "{locals.PROJECT_DIR}/modules/" // Maybe we can use omegaconf to help us with the config construction
        },
        "source3": {
            "type": "pip",
            "repository": "https://pypi.org/simple",
            "authentication": {
                "username": "env.USERNAME",
                "password": "env.PASSWORD"
            }
        }
    },
    "modules": [
        {
            "type": "referenced",
            "module_source": {
                "provider": "source1",
                // Do we keep these parameters the same for all providers assume we know how to link from module name and version?
                "module_name": "scorecarding", // This would require a module.json at modules/scorecarding/1.0/module.json with the relevant information about the module
                "module_version": "1.0"
            },
            "input_mapping": { // What makes more sense here? "internal_name": "external_name" or the other way around? I think the first one makes more sense since we can then use the same mapping for different modules if needed
                "risk_score": "merchant_risk_score",
                "transaction_amount": "amount"
            },
            "output_mapping": {
                "score": "merchant_score"
            },
            "internal_overrides": {
                "client_rpo": "specialised_rpo" // if there are internal functions of a dag that we want to override it might be nice to do so here that way we make fexability
            },
            "parameters": {
                "threshold": {"source": "value", "value": 0.7}, // This is an example of a static parameter that we want to pass to the module
                // not sure if below vs {"source": "source1", "source_name": "source1"}
                "max_risk_score": {"source": "parameter_source", "source_name": "source1", "key": "max_risk_score"}, // This is an example of a dynamic parameter that we want to pass to the module
                "risk_threshold": {"source": "parameter_source", "source_name": "source1", "key": "threshold_table.threshold_1.index=0"}, // maybe the result is a table so we do subkey or threshold_table.threshold_1.index=0
                "decision_table_thresholds": {"source": "parameter_source", "source_name": "source1", "key": "decision_table.thresholds"}
            }
        },
        {
            "type": "inline",
            "expression_set": {
                "scaled": "col('transaction_amount') / col('max_transaction_amount')",
                "offset": "col('scaled') - col('threshold')"
            },
            // Do we need an input and output map or can we assume that all outputs and inputs available in global space
            // we can do something like exposed_outputs: ["offset"] and then only expose those. 
            "parameters": {
                "threshold": {"source": "value", "value": 0.5},
                "max_transaction_amount": {"source": "parameter_source", "source_name": "source1", "key": "max_transaction_amount"}
            }
        },
        { 
            "type": "python_script",
            "script_path": "{locals.MODULE_PATH}/scripts/custom_script.py",
            // maybe we always just provide the below and if they are used we map them else we dont
            "input_mapping": {...},
            "output_mapping": {...},
            "internal_overrides": {...},
            "parameters": {...}
        },
        {
            "type": "namespace",
            "namespace": "data_processing",
            "modules": [...], // we can then nest modules inside the namespace that way we can have a nice structure for our modules
            "exposed_outputs": ["processed_data"] 
        }
    ]
}