{
    "name": "Example Module",
    "description": "This is an example module configuration.",
    "type": "project", // Type of the module (Top level component, namespaced, etc. tbd if this is needed here but might be useful to decide what parameters are needed)
    "metadata": {
        "author": "John Doe",
        "license": "MIT",
        "version": "1.0"
    },
    "parameter_sources": { // If we use the type field stuff like this might be something thats only defined on a project level
        "source1": {
            "type": "file",
            "path": "/data/source1.csv",
            "environment": "env.ENVIRONMENT", // Maybe we can have different parameters for different environments that way we can easily switch between them without having to change the config file
            "version": "1.0" // allow them to pin a version rather than always fetching the latest.
        },
        "source2": {
            "type": "database",
            "connection_string": "Server=myServerAddress;Database=myDataBase;User Id=myUsername;Password=myPassword;"
        },
        "source3": {
            "type": "environment_variable",
            "endpoint": "https://api.example.com/data"
        }
    },
    "module_sources": {
        "source1": {
            "type": "folder", // We could define a folder modules by default 
            "path": "{env.BASE_PATH}/modules/" // Maybe we can use omegaconf to help us with the config construction
        },
        "source2": {
            "type": "folder",
            "path": "{locals.PROJECT_DIR}/modules/" // Maybe we can use omegaconf to help us with the config construction
        },
        "source3": {
            "type": "pip",
            "repository": "https://pypi.org/simple",
            "authentication": {
                "username": "env.USERNAME",
                "password": "env.PASSWORD"
            }
        }
    },
    "modules": [
        {
            "type": "my_module", // The providers must have a function that can be called to say list_modules or some discovery and we can do some magic to go through providers in order to determine if it can provide the module
            "version":"1.0", // we can allow it to always fetch latest if this isnt provided and we should allow versioned modules as well as unversioned modules. Unless we always do versioned modules.
            "source": "source1", // Maybe we can allow a source override that skips the discovery process.
            "module_config": { // For custom modules like scorecard this can host the config for the scorecard
                "param1": "value1",
                "param2": "value2"
            },
            // "module_config": "{internal.MODULE_PATH}/scorecarding_config.json" // if someone wants to rather have the config separate to avoid bloating the flow? 
            // should we do a seperate module_config_path rather for validation. I think its easy enough in pydantic if str load from path if dict load dict
            "input_mapping": { // What makes more sense here? "internal_name": "external_name" or the other way around? I think the first one makes more sense since we can then use the same mapping for different modules if needed
                "risk_score": "merchant_risk_score",
                "transaction_amount": "amount"
            },
            "output_mapping": {
                "score": "merchant_score"
            },
            "internal_overrides": {
                "client_rpo": "specialised_rpo" // if there are internal functions of a dag that we want to override it might be nice to do so here that way we make fexability
            },
            "parameters": {
                "threshold": {"source": "value", "value": 0.7}, // This is an example of a static parameter that we want to pass to the module
                // not sure if below vs {"source": "source1", "source_name": "source1"}
                "max_risk_score": {"source": "parameter_source", "source_name": "source1", "key": "max_risk_score"}, // This is an example of a dynamic parameter that we want to pass to the module
                "risk_threshold": {"source": "parameter_source", "source_name": "source1", "key": "threshold_table.threshold_1.index=0"}, // maybe the result is a table so we do subkey or threshold_table.threshold_1.index=0
                "decision_table_thresholds": {"source": "parameter_source", "source_name": "source1", "key": "decision_table.thresholds"}
            }
        },
        {
            "type": "decision_table", // This is a module that is provided by a internal module provider
            "module_config":  { // This is where it might be userful to get it from a path rather
                "parameters": {
                    "columns": ["age_min", "age_max", "income_min", "valid_employment", "credit_min", "decision", "interest_rate", "max_loan"],
                    "values": "parameters.decision_table_values", // This is an example of a dynamic parameter that we want to pass to the module that is a table. We can then do some magic with the subkeys to determine how to pass it to the module. Maybe we can also allow it to be directly in the config as well if they dont want to have it as a parameter source
                    // The values would typically look like below so now we can fetch it from a parameter store to be more dynamic.
                    // "values": [
                    //     [25, 35, 50000, ["full_time", "contract"], 650, "approve", 3.5, 400000],
                    //     [30, 50, 70000, ["full_time", "contract"], 700, "approve", 3.2, 600000], 
                    //     [45, 65, 80000, ["full_time", "contract", "retired"], 680, "approve", 3.8, 500000],
                    //     [18, 70, 100000, ["full_time", "contract"], 600, "approve", 3.0, 800000],
                    //     [25, 45, 40000, ["full_time"], 700, "conditional", 4.2, 250000]
                    // ],
                    "dtypes": {
                        "age_min": "float",
                        "age_max": "float", 
                        "income_min": "float",
                        "valid_employment": "list[string]",
                        "credit_min": "float",
                        "decision": "string",
                        "interest_rate": "float",
                        "max_loan": "float"
                    }
                },
                "expression": {
                    "typ": "and",
                    "expressions": [
                        {
                            "typ": "between",
                            "variable": "age",
                            "lower_bound_column": "age_min", 
                            "upper_bound_column": "age_max",
                            "mode": "both_inclusive"
                        },
                        {
                            "typ": "between",
                            "variable": "income",
                            "lower_bound_column": "income_min",
                            "mode": "lower_inclusive"
                        },
                        {
                            "typ": "in",
                            "variable": "employment",
                            "values_column": "valid_employment"
                        },
                        {
                            "typ": "between",
                            "variable": "credit",
                            "lower_bound_column": "credit_min",
                            "mode": "lower_inclusive"
                        }
                    ]
                },
                "outputs": ["decision", "interest_rate", "max_loan"],
                "default": ["reject", 5.0, 0]
            },
            "input_mapping": {
                "age": "customer_age",
                "income": "customer_income",
                "employment": "customer_employment_status",
                "credit": "customer_credit_score"
            },
            "output_mapping": {
                "output": "table_output", // think we can decide that most modules will have one output called output. 
                // in this case there is the individual values from the output called "decision", "interest_rate", "max_loan"
                // so the moduel could output output as a struct but if you wanted a specific value you could also do
                "interest_rate": "customer_interest_rate" // And then all unmapped outputs would be hidden from the external graph space.
            }
        },
        {
            "type": "inline",
            "module_config": { // Do we do the nesting here. i think its needed to have one class be the dynamic module class that is used to route the pydantic model validates with the other moduls.
                "expression_set": { // not sure how we do this safely. does it matter? as if a user has access to this json they can anyway just include a python script as a module
                    "scaled": "col('transaction_amount') / parameter('max_transaction_amount')",
                    "offset": "col('scaled') - parameter('threshold')"
                }
            },
            // Do we need an input and output map or can we assume that all outputs and inputs available in global space
            // we can do something like exposed_outputs: ["offset"] and then only expose those. 
            "parameters": {
                "threshold": {"source": "value", "value": 0.5},
                "max_transaction_amount": {"source": "parameter_source", "source_name": "source1", "key": "max_transaction_amount"}
            }
        },
        { 
            "type": "python_script",
            // if above needs to be in module config then this should be in as well unless we have a set of internal module types that we handle and then if its not one of those we 
            // make use of a generic fallback module type that dynamically injects. which might be a better design.
            "script_path": "{locals.MODULE_PATH}/scripts/custom_script.py",
            // maybe we always just provide the below and if they are used we map them else we dont
            "input_mapping": {...},
            "output_mapping": {...},
            "internal_overrides": {...},
            "parameters": {...}
        },
        {
            "type": "namespace",
            "namespace": "data_processing",
            "modules": [...], // we can then nest modules inside the namespace that way we can have a nice structure for our modules
            "exposed_outputs": ["processed_data"] 
        }
    ]
}