{
    "type": "external",
    "name": "custom_example",
    "input_mapping": {},
    "input_name": "input",
    "output_name": "output",
    "modules": [
        {
            "type": "custom_example.eg1_with_config",
            "name": "eg1",
            "scale": "${ped.param:ext,scale}",
            "offset": "${ped.param:ext,offset}"
        },
        {
            "type": "custom_example.eg2",
            "name": "eg2",
            "input_mapping": {"raw": "eg1.adjusted"}
        },
        {
            "type": "custom_example.eg3",
            "name": "eg3",
            "multiplier": "${ped.param:ext,multiplier}",
            "constant": "${ped.param:ext,constant}",
            "input_mapping": {"i1": "eg2.capped"}
        }
    ],
    "outputs": ["eg3.c"]
}